{
  "name": "@shieldly/cdk-guard",
  "version": "1.3.1",
  "description": "AI-Powered AWS security analysis as a CDK Construct — catch risky IAM and CloudFormation in every cdk synth",
  "license": "MIT",
  "homepage": "https://www.shieldly.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shieldly-io/cdk-guard.git"
  },
  "bugs": {
    "url": "https://github.com/shieldly-io/cdk-guard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "cdk-guard": "dist/cdk-guard.cjs"
  },
  "files": [
    "src",
    "dist/cdk-guard.cjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "aws-cdk",
    "cdk",
    "cdk-construct",
    "constructs",
    "aws",
    "iam",
    "security",
    "cloudformation",
    "ai",
    "shieldly",
    "devsecops",
    "least-privilege",
    "policy-analysis"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node build.js",
    "build:dev": "node build.js --dev",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "aws-cdk-lib": ">=2.0.0",
    "constructs": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "aws-cdk-lib": {
      "optional": true
    },
    "constructs": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
